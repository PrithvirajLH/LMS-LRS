# ── Azure Storage ────────────────────────────────────────────────
# Connection string for Azure Table Storage + Blob Storage.
# Get this from: Azure Portal → Storage Account → Access Keys
# In production, use Azure Key Vault instead of storing the key here.
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;BlobEndpoint=https://YOUR_ACCOUNT.blob.core.windows.net/;QueueEndpoint=https://YOUR_ACCOUNT.queue.core.windows.net/;TableEndpoint=https://YOUR_ACCOUNT.table.core.windows.net/;FileEndpoint=https://YOUR_ACCOUNT.file.core.windows.net/;

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Required in production. Omit for dev (allows all origins in dev mode).
# Example: https://lms.example.com,https://storyline.example.com
# ALLOWED_ORIGINS=https://lms.yourcompany.com

# ── Node Environment ─────────────────────────────────────────────
# Set to "production" for production deployments.
# Controls: secure cookies, CORS strictness, dev-only features.
# NODE_ENV=production
